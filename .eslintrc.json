{
  "extends": [
    "next/core-web-vitals",
    "plugin:jsx-a11y/recommended",
    "prettier",
    "plugin:storybook/recommended"
  ],
  "rules": {
    "no-empty": ["error", { "allowEmptyCatch": false }],
    "react/prop-types": "off"
  },
  "overrides": [
    {
      "files": ["client_types/**/*.ts"],
      "rules": {
        "@typescript-eslint/no-unused-vars": "off",
        "no-unused-vars": "off"
      }
    }
  ]
}
